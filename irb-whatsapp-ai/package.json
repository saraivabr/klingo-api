{
  "name": "irb-whatsapp-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @irb/api dev",
    "dev:worker": "pnpm --filter @irb/worker dev",
    "dev:dashboard": "pnpm --filter @irb/dashboard dev",
    "dev:site": "pnpm --filter @irb/site dev",
    "build:site": "pnpm --filter @irb/site build",
    "deploy:site": "bash scripts/deploy-site.sh",
    "dev:all": "pnpm run --parallel dev:api dev:worker dev:dashboard",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @irb/database db:generate",
    "db:migrate": "pnpm --filter @irb/database db:migrate",
    "db:seed": "pnpm --filter @irb/database db:seed",
    "db:indexes": "node scripts/add-mongodb-indexes.js",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
