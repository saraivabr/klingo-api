# =============================================================
# IRB EFD-Reinf — variáveis de ambiente
# Copie para .env e preencha com os valores reais
# =============================================================

# ============================
# AMBIENTE
# ============================
# pre_producao | producao
REINF_AMBIENTE=pre_producao

# ============================
# CONTRIBUINTE (DECLARANTE)
# ============================
# CNPJ matriz (sem máscara, 14 dígitos)
CONTRIB_CNPJ=37787172000167
CONTRIB_NOME=IRB Prime Care Servicos Medicos Clinicos Hospitalares LTDA

# ============================
# SCP (Sociedade em Conta de Participação)
# ============================
SCP_CNPJ=39403031000129
SCP_NOME=IVAN ROBERTO BARBIERI LTDA SCP
# Data de validade inicial do registro R-1050 (formato AAAA-MM)
SCP_INICIO_VALIDADE=2025-01

# ============================
# CERTIFICADO DIGITAL A1
# ============================
CERT_A1_PATH=/Users/saraiva/irb-reinf/certs/scp.pfx
CERT_A1_SENHA=

# ============================
# RESPONSÁVEL PELAS INFORMAÇÕES
# ============================
RESPONSAVEL_NOME=DENIS CRISTIANO KIM
RESPONSAVEL_CPF=

# ============================
# E-MAIL (envio dos informes)
# ============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=IRB Prime Care
SMTP_FROM_EMAIL=naoresponder@irbgsaude.com.br

# ============================
# WHATSAPP (uazapi)
# ============================
UAZAPI_BASE_URL=https://free.uazapi.com
UAZAPI_TOKEN=
UAZAPI_INSTANCE=

# ============================
# DASHBOARD
# ============================
DASHBOARD_PORT=8080
DASHBOARD_USER=admin
DASHBOARD_PASS=

# ============================
# DATABASE
# ============================
DATABASE_URL=sqlite:///data/irb-reinf.db
